{
  "name": "fundamentals-project-ts-template",
  "version": "1.0.0",
  "description": "Capstone Project TS Template",
  "main": "index.js",
  "scripts": {
    "sass": "sass src/scss/main.scss dist/css/main.css --watch --style=expanded",
    "ts-compile": "npx tsc --watch",
    "dev": "npm run sass & npm run ts-compile",
    
